rules_version = '2';

// Ogbaje Firestore security rules — deploy from the Firebase console
// (Firestore Database → Rules) or `firebase deploy --only firestore:rules`.
//
// Model (docs/DATA-MODEL.md): owners write their own data; alert reads are
// restricted to the owner and the recipients named on the alert.
//
// DEMO NOTE: the web dashboard is unauthenticated for the hackathon demo, so
// alert reads below also allow anyone HOLDING THE ALERT LINK (get by id) —
// list queries stay locked to recipients. Tighten for production by removing
// the marked line and adding dashboard sign-in.
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid} {
      allow read: if request.auth != null;           // needed for phone-number lookup
      allow create, update: if request.auth != null && request.auth.uid == uid;
      allow delete: if false;

      match /contacts/{contactId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Registration-time linkedUid backfill (users.ts) touches other users'
    // contact docs via collectionGroup — allow ONLY that one field flip.
    match /{path=**}/contacts/{contactId} {
      allow read: if request.auth != null;
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['linkedUid'])
        && resource.data.linkedUid == null
        && request.resource.data.linkedUid == request.auth.uid;
    }

    match /alerts/{alertId} {
      allow create: if request.auth != null
        && request.resource.data.ownerUid == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.ownerUid == request.auth.uid;
      allow get: if true;                            // DEMO: link = access (see note above)
      allow list: if request.auth != null
        && (resource.data.ownerUid == request.auth.uid
            || request.auth.uid in resource.data.recipientUids);
      allow delete: if false;

      match /locations/{pointId} {
        allow read: if true;                         // DEMO: link = access
        allow write: if request.auth != null
          && get(/databases/$(database)/documents/alerts/$(alertId)).data.ownerUid == request.auth.uid;
      }

      match /photos/{photoId} {
        allow read: if true;                         // DEMO: link = access
        allow write: if request.auth != null
          && get(/databases/$(database)/documents/alerts/$(alertId)).data.ownerUid == request.auth.uid;
      }

      match /timeline/{eventId} {
        allow read: if true;                         // DEMO: link = access
        // Owner writes engine events; any signed-in user may add contact-viewed.
        allow create: if request.auth != null;
        allow update, delete: if false;
      }
    }

    match /checkins/{checkinId} {
      allow create: if request.auth != null
        && request.resource.data.ownerUid == request.auth.uid;
      allow read, update: if request.auth != null
        && resource.data.ownerUid == request.auth.uid;
      allow delete: if false;
    }
  }
}
